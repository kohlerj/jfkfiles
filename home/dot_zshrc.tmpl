{{/* zsh config — chezmoi template, portable across macOS and immutable Linux */ -}}
# Managed by chezmoi. Edit in the jfkfiles repo, not here.

setopt AUTOCD
setopt NOBEEP
setopt NUMERIC_GLOB_SORT

# Path to oh-my-zsh
export ZSH="$HOME/.oh-my-zsh"

zstyle ':omz:update' frequency 13
ENABLE_CORRECTION="true"

# EZA
zstyle ':omz:plugins:eza' 'header' yes
zstyle ':omz:plugins:eza' 'git-status' yes

# FZF
export FZF_DEFAULT_COMMAND='fd --type f --hidden --exclude .git --strip-cwd-prefix'
export FZF_DEFAULT_OPTS='
  --height=60%
  --layout=reverse
  --border=rounded
  --prompt="  "
  --pointer="  "
  --preview-window=right:65%:wrap:border-left
'
export _FZF_PREVIEW_CMD='bat --color=always --style=plain,numbers --line-range=:500 {}'
export FZF_CTRL_T_OPTS="--preview '$_FZF_PREVIEW_CMD'"

# Plugins ('macos' only loaded on Darwin so config stays Linux-portable)
plugins=(git python pyenv virtualenv dotenv zoxide fzf colorize tmux eza{{ if eq .chezmoi.os "darwin" }} macos{{ end }})

source $ZSH/oh-my-zsh.sh

# Aliases
alias zshconfig="$EDITOR ~/.zshrc"
alias tree='eza --tree --icons'
compdef eza=ls

# Local bin
export PATH="$HOME/.local/bin:$PATH"

{{ if eq .chezmoi.os "darwin" -}}
# Embedded: Pico SDK (host tooling — migrate into a devcontainer where possible)
[ -d "$HOME/Sources/pico/pico-sdk" ] && export PICO_SDK_PATH="$HOME/Sources/pico/pico-sdk"
{{ end -}}

# Brew shellenv (path differs on Apple Silicon vs Linuxbrew)
{{ if eq .chezmoi.os "darwin" -}}
[ -x /opt/homebrew/bin/brew ] && eval "$(/opt/homebrew/bin/brew shellenv)"
{{ else -}}
[ -x /home/linuxbrew/.linuxbrew/bin/brew ] && eval "$(/home/linuxbrew/.linuxbrew/bin/brew shellenv)"
{{ end -}}

eval "$(starship init zsh)"
