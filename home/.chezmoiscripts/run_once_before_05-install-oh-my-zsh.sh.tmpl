#!/bin/sh
# Install oh-my-zsh if missing (needed by dot_zshrc on any OS).
# KEEP_ZSHRC=yes so it never overwrites the chezmoi-managed ~/.zshrc.
set -eu
{{ $linuxVariant := dig "data" "linuxVariant" "" . -}}
{{- if and (eq .chezmoi.os "linux") (eq $linuxVariant "") -}}
{{-   $osID := index .chezmoi.osRelease "id" | default "" -}}
{{-   if and (eq $osID "fedora") (stat "/run/ostree-booted") -}}
{{-     $linuxVariant = "fedora-atomic" -}}
{{-   else if eq $osID "alpine" -}}
{{-     $linuxVariant = "alpine" -}}
{{-   else if or (eq $osID "debian") (eq $osID "ubuntu") -}}
{{-     $linuxVariant = "debian" -}}
{{-   else -}}
{{-     $linuxVariant = "linux" -}}
{{-   end -}}
{{- end -}}

if [ ! -d "$HOME/.oh-my-zsh" ]; then
{{ if eq .chezmoi.os "linux" -}}
{{ if eq $linuxVariant "alpine" -}}
    if ! command -v curl >/dev/null 2>&1 || ! command -v git >/dev/null 2>&1; then
        echo "==> Installing prerequisites for oh-my-zsh (curl, git)"
        sudo apk add --no-cache curl git
    fi
{{ else if eq $linuxVariant "debian" -}}
    if ! command -v curl >/dev/null 2>&1 || ! command -v git >/dev/null 2>&1; then
        echo "==> Installing prerequisites for oh-my-zsh (curl, git)"
        sudo apt-get update -qq
        sudo apt-get install -y --no-install-recommends curl git
    fi
{{ else -}}
    if ! command -v curl >/dev/null 2>&1; then
        echo "curl is required to install oh-my-zsh. Please install curl first." >&2
        exit 1
    fi
{{ end -}}
{{ end -}}
    if ! command -v curl >/dev/null 2>&1; then
        echo "curl is required to install oh-my-zsh. Please install curl first." >&2
        exit 1
    fi

    echo "==> Installing oh-my-zsh"
    RUNZSH=no CHSH=no KEEP_ZSHRC=yes \
        sh -c "$(curl -fsSL https://raw.githubusercontent.com/ohmyzsh/ohmyzsh/master/tools/install.sh)"
fi
